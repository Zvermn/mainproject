# Локально с `npm run dev` / `dev:pwa`: прокси quasar → http://erp.local (без hosts в браузере)
VITE_ERP_API_BASE_URL=/erp-api/api
# Прямой вызов из браузера: http://erp.local/api (нужны hosts + CORS)
# VITE_ERP_API_BASE_URL=http://erp.local/api

VITE_ERP_SITE_ID=2

# Dev: без /auth/sms/issue, вход только через /auth/sms/dev-login (в ERP: APP_ENV=local + SMS_LOGIN_DEV_BYPASS=true)
VITE_SMS_LOGIN_DEV_MOCK=true
VITE_SMS_LOGIN_DEV_CODE=777777
